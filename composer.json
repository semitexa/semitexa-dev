{
  "name": "semitexa/dev",
  "description": "Semitexa Dev - code generators and capability-aware CLI tooling for application scaffolding",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Semitexa",
      "email": "support@semitexa.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "semitexa/core": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Semitexa\\Dev\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Semitexa\\Dev\\Tests\\": "tests/"
    }
  },
  "keywords": [
    "semitexa",
    "dev",
    "generators",
    "scaffolding",
    "cli",
    "capabilities"
  ]
}
